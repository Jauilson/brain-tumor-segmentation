# Brain Tumor Segmentation - .gitignore

# ── Dataset (too large for GitHub) ────────────────────────────────────────
data/
dataset/
databrain/
*.nii
*.nii.gz

# ── Model checkpoints & saved models ──────────────────────────────────────
*.h5
*.hdf5
*.keras
best_*.h5
checkpoints/
saved_models/

# ── Results and outputs ────────────────────────────────────────────────────
# Remove the block below if you want to commit result images to GitHub
results/
outputs/
*.png
*.jpg
*.jpeg
*.pdf

# ── Sensitive/private project files ───────────────────────────────────────
uteis/

# ── Python ─────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# ── Virtual environments ───────────────────────────────────────────────────
venv/
env/
ENV/
env.bak/
venv.bak/

# ── Jupyter Notebook ──────────────────────────────────────────────────────
.ipynb_checkpoints
*/.ipynb_checkpoints/*

# ── IPython ────────────────────────────────────────────────────────────────
profile_default/
ipython_config.py

# ── IDEs ───────────────────────────────────────────────────────────────────
.idea/
.vscode/
.spyderproject
.spyproject
.ropeproject

# ── OS ─────────────────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
ehthumbs.db
Desktop.ini
*~

# ── Logs & TensorBoard ─────────────────────────────────────────────────────
*.log
logs/
events.out.tfevents.*
runs/

# ── Temporary files ────────────────────────────────────────────────────────
*.tmp
*.bak
*.swp
*.swo

# ── Google Drive / Colab ───────────────────────────────────────────────────
.gdrive/
gdrive/
drive/
*_colab.ipynb
